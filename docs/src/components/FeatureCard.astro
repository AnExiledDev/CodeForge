---
interface Props {
	title: string;
	description: string;
	icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="feature-card">
	<div class="feature-card__icon" set:html={icon} />
	<h3 class="feature-card__title">{title}</h3>
	<p class="feature-card__description">{description}</p>
</div>

<style>
	.feature-card__icon {
		font-size: 1.75rem;
		margin-bottom: 0.75rem;
		line-height: 1;
		color: var(--color-ember-400);
	}

	.feature-card__icon :global(svg) {
		width: 1.75rem;
		height: 1.75rem;
	}

	.feature-card__title {
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--color-charcoal-50);
		margin: 0 0 0.5rem;
		line-height: 1.3;
	}

	.feature-card__description {
		font-size: 0.925rem;
		color: var(--color-charcoal-400);
		line-height: 1.55;
		margin: 0;
	}
</style>
